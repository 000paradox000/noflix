root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 79

# Makefiles require tabs
[{Makefile,*.mk,**/*.mk}]
indent_style = tab

# Docker Compose files commonly use 2-space indentation
[**/docker-compose.{yml,yaml}]
indent_size = 2

# HTML files
[*.html]
indent_size = 2
max_line_length = 120
